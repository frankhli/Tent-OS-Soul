# ========== 轻量级追问生成器（零LLM调用）==========
FOLLOW_UP_TEMPLATES = {
    "choice": ["你为什么选择这个？", "有没有考虑过其他选项？", "这个选择对你来说意味着什么？"],
    "emotion": ["你当时是什么感觉？", "那种情绪对你影响大吗？", "后来你是怎么调整过来的？"],
    "place": ["那个地方对你有什么特殊意义？", "你最喜欢那里的什么？", "还有类似让你印象深刻的地方吗？"],
    "memory": ["能再多说一些那时候的事吗？", "那件事之后发生了什么？", "你还记得什么细节？"],
    "person": ["TA 对你影响最大的是什么？", "你们是怎么认识的？", "你们现在还有联系吗？"],
    "advice": ["你是怎么想到这个的？", "这个想法是从什么时候开始有的？", "有没有人给过你类似的建议？"],
    "dream": ["你为什么想实现这个？", "你为此做过什么努力？", "实现之后你最想做什么？"],
    "difficulty": ["那段时间你是怎么挺过来的？", "有没有谁帮助过你？", "现在你回头看有什么感悟？"],
    "work": ["这份工作/项目中最让你满意的部分是什么？", "过程中遇到过什么挑战吗？", "团队里谁给你的帮助最大？"],
    "family": ["家里人对这件事怎么看？", "你们平时的相处模式是怎样的？", "这件事对家庭关系有什么影响？"],
}

FOLLOW_UP_KEYWORDS = {
    "choice": ["选择", "决定", "选", "抉择", "取舍", "比较", "权衡"],
    "emotion": ["感觉", "心情", "情绪", "难过", "开心", "高兴", "伤心", "激动", "平静", "焦虑", "害怕", "愤怒", "满足", "失落"],
    "place": ["地方", "城市", "国家", "学校", "家乡", "北京", "上海", "广州", "深圳", "成都", "杭州", "西安"],
    "memory": ["以前", "小时候", "记得", "回忆", "那时", "曾经", "过去", "往事", "童年", "青春"],
    "person": ["朋友", "同事", "家人", "父母", "孩子", "兄弟", "姐妹", "他", "她", "他们", "老师", "领导", "老板"],
    "advice": ["建议", "应该", "可以", "试试", "推荐", "建议", "方法", "策略", "技巧"],
    "dream": ["想", "希望", "梦想", "目标", "愿望", "规划", "打算", "期待", "向往"],
    "difficulty": ["困难", "挑战", "痛苦", "挣扎", "坚持", "挫折", "失败", "压力", "迷茫", "困惑", "不容易"],
    "work": ["工作", "项目", "公司", "团队", "业务", "客户", "产品", "开发", "设计", "运营", "管理"],
    "family": ["家里", "父母", "孩子", "妻子", "丈夫", "老婆", "老公", "家人", "家庭", "亲戚"],
}

FOLLOW_UP_GENERIC = [
    "能再多说一些吗？",
    "后来呢？",
    "你为什么会这么想？",
    "那对你意味着什么？",
    "还有没有类似的？",
]

def generate_follow_ups(ai_response: str, user_message: str = "") -> List[str]:
    """基于AI回复内容，零LLM生成1-3个自然追问"""
    if not ai_response or len(ai_response) < 20:
        return []
    
    text = ai_response + " " + user_message
    matched_categories = set()
    
    for category, keywords in FOLLOW_UP_KEYWORDS.items():
        for kw in keywords:
            if kw in text:
                matched_categories.add(category)
                break
    
    questions = []
    if matched_categories:
        # 从匹配的类别中随机选2个，每个类别随机选1个问题
        selected_cats = random.sample(list(matched_categories), min(2, len(matched_categories)))
        for cat in selected_cats:
            q = random.choice(FOLLOW_UP_TEMPLATES[cat])
            if q not in questions:
                questions.append(q)
    
    # 如果没有匹配到，或者问题太少，补充通用追问
    if len(questions) < 2:
        generics = [q for q in FOLLOW_UP_GENERIC if q not in questions]
        while len(questions) < 2 and generics:
            q = random.choice(generics)
            generics.remove(q)
            if q not in questions:
                questions.append(q)
    
    # 最多返回3个
    return questions[:3]
